labs(title = "Predicted vs Actual Logit Index",
x = "Predicted Logit Index",
y = "Actual Logit Index") +
theme_minimal()
model5 <- lm(logit_index ~ Gender  + poly(Sleep.Duration,2,raw = T) + Quality.of.Sleep, data = df)
